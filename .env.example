# Ollama local LLM settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b

# Optional: Cloud LLM fallback
CLOUD_LLM_PROVIDER=none      # options: none, openai, anthropic
CLOUD_LLM_MODEL=             # e.g. gpt-4o or claude-3-5-sonnet-20241022
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# HuggingFace
HF_TOKEN=                    # required for pushing to vlbthambawita/ECGBench
HF_REPO_ID=vlbthambawita/ECGBench

# GitHub
GITHUB_TOKEN=                # required for updating vlbthambawita/CardioMAS README
GITHUB_REPO=vlbthambawita/CardioMAS

# Data storage
CARDIOMAS_DATA_DIR=~/.cardiomas/data

# Reproducibility
CARDIOMAS_SEED=42
